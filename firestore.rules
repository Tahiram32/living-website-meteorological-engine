rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /clients/{domain} {
      allow read: if true;
      allow write: if false;
    }
    match /runs/{runId} {
      allow read: if true;
      allow write: if false;
    }
    match /paypal_transactions/{txId} {
      allow read, write: if false;
    }
  }
}
