# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PAYPAL CREDENTIALS (Configure in your AI Studio Settings > Secrets)
# PayPal Environment: "sandbox" or "production"
PAYPAL_ENV="sandbox"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""

# FIREBASE ADMIN SERVICE ACCOUNT KEY (Configure in AI Studio Settings > Secrets)
# A stringified JSON of your Google Cloud Service Account Key with Cloud Datastore User permissions
FIREBASE_SERVICE_ACCOUNT_KEY=""

# ENTERPRISE WEATHER SLA API KEY (Optional - falls back to Open-Meteo/NWS if blank)
WEATHER_API_KEY=""

# GOOGLE CLOUD TASKS DISTRIBUTED QUEUE CONFIGURATION (Optional - falls back to high-fidelity Sim Queue if blank)
GCP_PROJECT_ID=""
GCP_LOCATION_ID=""
GCP_QUEUE_ID=""
TASK_WORKER_SECRET="sec_default_task_secret"

